# Cortex Platform Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=Cortex Platform
APP_ENV=production
APP_DEBUG=false
APP_PORT=3000
APP_HOST=0.0.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cortex_platform
DB_USER=cortex_user
DB_PASSWORD=your_secure_password_here

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d
SESSION_SECRET=your_session_secret_here

# API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@cortexplatform.com

# Payment Processing
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=cortex-platform-bucket

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=mixpanel

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# External Services
WEBHOOK_URL=https://your-domain.com/webhooks
API_VERSION=v1

# Platform Settings
PLATFORM_NAME=Cortex Platform
SUPPORT_EMAIL=support@cortexplatform.com